# HTTPS config for api.chessr.io — mirrors beta.chessr.io.conf so the
# extension can be republished with VITE_WS_URL=wss://api.chessr.io and
# the v3 serveur handles all the same routes (Paddle, Discord OAuth,
# wheel, giveaway, tickets, /health, /ws). Disabled by default; rename
# to .conf after certbot has issued the cert under
# /etc/letsencrypt/live/api.chessr.io/.

server {
    listen 80;
    listen [::]:80;
    server_name api.chessr.io;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name api.chessr.io;

    ssl_certificate     /etc/letsencrypt/live/api.chessr.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.chessr.io/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    client_max_body_size  2m;
    proxy_read_timeout    3600s;
    proxy_send_timeout    3600s;
    proxy_connect_timeout 30s;

    resolver 127.0.0.11 valid=10s ipv6=off;
    set $serveur_upstream "http://serveur:8081";

    # WebSocket upgrade.
    location /ws {
        proxy_pass $serveur_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass $serveur_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
