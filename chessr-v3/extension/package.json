{
  "name": "chessrv3",
  "version": "3.0.1",
  "description": "Chessr - Chess assistant extension",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt zip",
    "build:beta": "wxt zip --mode beta",
    "deploy:beta": "wxt zip --mode beta && bash scripts/upload-beta.sh",
    "build:firefox": "wxt build --browser firefox",
    "test": "tsx --test entrypoints/content/lib/__tests__/*.test.ts",
    "postinstall": "wxt prepare && node scripts/copy-engines.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.103.3",
    "@wxt-dev/module-react": "^1.2.2",
    "chess.js": "^1.4.0",
    "gsap": "^3.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stockfish": "^18.0.7",
    "wxt": "^0.20.23",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "javascript-obfuscator": "^5.4.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
