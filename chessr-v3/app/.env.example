# Chessr.io app — runs the game review and profile analysis flows.
# Talks to the chessr-v3 serveur for engine work via WebSocket.
#
# Copy this to .env.local and fill in the blanks. For prod the
# values come from the chessr-beta VPS docker-compose env block.

# ─── chessr-v3 serveur ─────────────────────────────────────────────────
# WebSocket endpoint for analysis / review streams. Points at api.chessr.io
# in prod (= the chessr-v3 serveur container behind nginx on chessr-beta).
# Local dev: ws://localhost:8081 if you're running the serveur on your laptop.
NEXT_PUBLIC_CHESSR_WS_URL=wss://api.chessr.io

# Shared secret used by the v3 serveur to recognize the chessr.io app
# (vs. random bots that forge a Supabase token). MUST match the serveur's
# APP_AUTH_TOKEN env. NEXT_PUBLIC_ exposes it in the client bundle, which
# is acceptable here: the value is paired with the user's Supabase
# access_token (verified server-side) — leaking the appToken alone gives
# no access, you still need a valid user session.
NEXT_PUBLIC_APP_AUTH_TOKEN=replace-with-the-app-auth-token-from-the-serveur-env

# ─── Supabase ─────────────────────────────────────────────────────────
# Same project as the rest of chessr-v3 (auth + user_settings + linked_accounts).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Optional ─────────────────────────────────────────────────────────
# Discord webhook used by /api/* routes that broadcast major events
# (e.g. a notable game review). Empty / unset → those routes silently
# skip the webhook step.
DISCORD_WEBHOOK_URL=
