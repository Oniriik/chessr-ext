# Discord
# Bot token from https://discord.com/developers/applications/<app>/bot
DISCORD_BOT_TOKEN=

# Application (client) ID — same page, "General Information"
DISCORD_CLIENT_ID=

# Guild ID where slash commands register. Guild-scoped registration is
# instant; global registration takes ~1h to propagate. Use a guild ID
# during dev, leave empty in prod for global commands.
DISCORD_GUILD_ID=

# Supabase (service role — read/write user_settings etc.)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis (events fanout — same instance the serveur uses for BullMQ)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Serveur HTTP base + admin token — used for slash commands that need
# live data (e.g. /connected). Same token serveur expects on /admin/*.
SERVEUR_URL=http://serveur:8080
SERVEUR_ADMIN_TOKEN=

# Plan → Discord role mapping. Each id is a role on the guild defined
# above. Leave a value empty to skip that tier (no role assigned for it).
# Free is included as a real role: linked-but-free users still see their
# tier in Discord. The "no role" state is reserved for users who have
# unlinked or been deleted — handled separately in the unlink/delete
# event handlers.
DISCORD_ROLE_ID_FREE=
DISCORD_ROLE_ID_FREETRIAL=
DISCORD_ROLE_ID_PREMIUM=
DISCORD_ROLE_ID_BETA=
DISCORD_ROLE_ID_LIFETIME=

# Logging level: debug | info | warn | error
LOG_LEVEL=info
